generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  PAUSED
  CANCELLED
}

enum SubscriptionFrequency {
  WEEKLY
  MONTHLY
  YEARLY
}

enum DetectionSource {
  MANUAL
  AUTO
}

enum FamilyRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id                String         @id @default(uuid()) @db.Uuid
  name              String         @db.VarChar(120)
  email             String         @unique @db.VarChar(180)
  passwordHash      String         @db.VarChar(255)
  role              UserRole       @default(USER)
  avatarUrl         String?        @db.VarChar(500)
  currency          String         @default("BRL") @db.VarChar(10)
  timezone          String         @default("America/Sao_Paulo") @db.VarChar(80)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  transactions      Transaction[]
  categories        Category[]
  goals             Goal[]
  subscriptions     Subscription[]
  ownedFamilyGroups FamilyGroup[]  @relation("FamilyGroupOwner")
  familyMemberships FamilyMember[]
}

model Category {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String?         @db.Uuid
  name          String          @db.VarChar(120)
  type          TransactionType
  icon          String?         @db.VarChar(80)
  color         String?         @db.VarChar(20)
  keywords      String[]        @default([])
  isDefault     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  subscriptions Subscription[]

  @@unique([userId, name, type])
  @@index([userId])
}

model Transaction {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @db.Uuid
  categoryId    String          @db.Uuid
  familyGroupId String?         @db.Uuid
  type          TransactionType
  amount        Decimal         @db.Decimal(14, 2)
  description   String          @db.VarChar(255)
  occurredAt    DateTime
  paymentMethod String?         @db.VarChar(60)
  isRecurring   Boolean         @default(false)
  merchant      String?         @db.VarChar(120)
  tags          String[]        @default([])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  familyGroup   FamilyGroup?    @relation(fields: [familyGroupId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([categoryId, occurredAt])
  @@index([familyGroupId, occurredAt])
}

model Goal {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @db.Uuid
  title         String     @db.VarChar(140)
  description   String?    @db.VarChar(400)
  targetAmount  Decimal    @db.Decimal(14, 2)
  currentAmount Decimal    @default(0) @db.Decimal(14, 2)
  deadline      DateTime?
  status        GoalStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Subscription {
  id              String                @id @default(uuid()) @db.Uuid
  userId          String                @db.Uuid
  categoryId      String?               @db.Uuid
  name            String                @db.VarChar(140)
  amount          Decimal               @db.Decimal(14, 2)
  frequency       SubscriptionFrequency
  nextChargeDate  DateTime
  isActive        Boolean               @default(true)
  detectionSource DetectionSource       @default(MANUAL)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, nextChargeDate])
  @@index([categoryId])
}

model FamilyGroup {
  id           String         @id @default(uuid()) @db.Uuid
  name         String         @db.VarChar(140)
  ownerUserId  String         @db.Uuid
  inviteCode   String         @unique @db.VarChar(20)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  owner        User           @relation("FamilyGroupOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members      FamilyMember[]
  transactions Transaction[]

  @@index([ownerUserId])
}

model FamilyMember {
  id            String      @id @default(uuid()) @db.Uuid
  familyGroupId String      @db.Uuid
  userId        String      @db.Uuid
  role          FamilyRole  @default(MEMBER)
  joinedAt      DateTime    @default(now())
  familyGroup   FamilyGroup @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyGroupId, userId])
  @@index([userId])
}
